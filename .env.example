### Public
FLASK_APP="src/server"
FLASK_ENV="development"
LOCAL_AUTH_USER_CODE="local-user"
LOCAL_AUTH_PASSWORD="local-pass"
DEBUG="True"

FIRESTORE_PROJECT_ID="simple-alert-line-bot"
FIRESTORE_EMULATOR_HOST=""
GOOGLE_APPLICATION_CREDENTIALS=""

# 規約・プライバシーポリシー表示用（無料βはハンドル名を既定、有料化時に特商法表記へ差し替え）
SERVICE_PROVIDER_NAME="fezzlk"
# 問い合わせフォームURL（Googleフォーム等）。公開前に設定すること。未設定時はLINEトーク案内にフォールバック
CONTACT_FORM_URL=""

### Private
